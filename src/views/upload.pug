extends layout.pug

block content
  if errorMessage
    span= errorMessage
  form(method="POST")
    input(
      name="title",
      placeholder="Title",
      required,
      type="text",
      maxlength=80
    )
    input(
      name="description",
      placeholder="Description",
      required,
      type="text",
      minlength=20
    )
    input(
      name="hashtags",
      placeholder="Hashtags, separated by comma.",
      type="text",
      required
    )
    input(type="submit", value="Upload Video")
